{
  "name": "fdp-online",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">= 24.0.0",
    "pnpm": ">= 9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:e2e": "playwright test --config=playwright.config.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.tests.json",
    "sandcastle:cron": "tsx .sandcastle/main.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "phaser": "3.80.1"
  },
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.5.6",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.9.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
