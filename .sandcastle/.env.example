# Autenticação GitHub (obrigatória para todas as operações do cron)
GITHUB_TOKEN=

# ============================================================
# AGENTE GLOBAL
# ============================================================
# Define qual agente será usado na execução.
# Valores suportados: codex | pi
# Padrão: codex
SANDCASTLE_AGENT=codex

# ============================================================
# CODEX (usado quando SANDCASTLE_AGENT=codex)
# ============================================================
# Autenticação OpenAI: obrigatória se `codex login` NÃO foi executado no host.
# Quando `codex login` está presente, esta variável é opcional.
OPENAI_API_KEY=

# Override opcional do modelo do Codex.
# Padrão: gpt-5.4
SANDCASTLE_CODEX_MODEL=

# Override opcional do esforço de raciocínio do Codex.
# Valores suportados: low | medium | high | xhigh
# Padrão: low
SANDCASTLE_CODEX_EFFORT=

# ============================================================
# PI (usado quando SANDCASTLE_AGENT=pi)
# ============================================================
# Autenticação Opencode: obrigatória para o agente Pi.
OPENCODE_API_KEY=

# Modelo usado pelo Pi. Use `pi --list-models` para ver alternativas.
# Padrão: opencode-go/mimo-v2-pro
SANDCASTLE_PI_MODEL=opencode-go/mimo-v2-pro

# Override opcional do nível de thinking do Pi.
# Valores suportados: off | minimal | low | medium | high | xhigh
# Padrão: medium
SANDCASTLE_PI_EFFORT=
